{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "module": "es6",
    "target": "es5",
    "allowJs": true,
    "baseUrl": "./",
    "paths": {
      "extendable-media-recorder": ["node_modules/extendable-media-recorder"],
      "extendable-media-recorder-wav-encoder": ["node_modules/extendable-media-recorder-wav-encoder"]
    },
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true
  },
  "files": [
    "./src/index.ts"
  ],
}
